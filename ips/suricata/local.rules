alert icmp any any -> any any (msg:"LAB ICMP Ping Detected"; sid:1000001; rev:1;)

alert tcp any any -> 192.168.2.100 any (msg:"LAB Port scan detected"; flags:S; threshold:type both, track by_src, count 20, seconds 10; classtype:attempted-recon; sid:1000002; rev:1;)

alert http any any -> 192.168.2.100 5000 (msg:"LAB WEB brute force - repeated POST /login"; flow:established,to_server; http.method; content:"POST"; http.uri; content:"/login"; detection_filter:track by_src, count 3, seconds 10; classtype:web-application-attack; sid:1000003; rev:1;)

alert http any any -> 192.168.2.100 5000 (msg:"LAB WEB credential stuffing - excessive POST /login"; flow:established,to_server; http.method; content:"POST"; http.uri; content:"/login"; detection_filter:track by_src, count 12, seconds 30; classtype:web-application-attack; sid:1000004; rev:1;)

alert http any any -> 192.168.2.100 5000 (msg:"LAB WEB admin page access"; flow:established,to_server; http.uri; content:"/admin"; classtype:web-application-activity; sid:1000008; rev:1;)

alert tcp any any -> 192.168.2.100 5000 (msg:"TEST TCP HIT"; sid:9999999; rev:1;)
